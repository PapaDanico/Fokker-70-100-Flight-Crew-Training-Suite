{
  "name": "@dnca/api",
  "version": "0.0.1",
  "private": true,
  "description": "Backend API for the DNCA Flight Crew Training Platform (Fastify, ADR 0007)",
  "type": "module",
  "main": "./src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node --import tsx src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint TBD'",
    "test": "node --test --import tsx 'test/**/*.test.ts'"
  },
  "dependencies": {
    "@dnca/db": "workspace:*",
    "@dnca/domain": "workspace:*",
    "@dnca/ontology": "workspace:*",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/sensible": "^6.0.0",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.0",
    "jose": "^5",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}

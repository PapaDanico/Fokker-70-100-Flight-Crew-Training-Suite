# --------------------------------------------------------------------------
# apps/api environment configuration
#
# Copy to apps/api/.env for local dev. In AWS af-south-1 production these
# come from Secrets Manager / Parameter Store; in CI they come from
# GitHub Actions secrets.
# --------------------------------------------------------------------------

NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# Postgres connection. Local dev: docker compose up postgres.
DATABASE_URL=postgres://app_runtime:dev@localhost:5432/fokker_dev

# CORS allowlist for apps/web. Comma-separated; production = the Vercel
# production URL once issued.
CORS_ORIGINS=http://localhost:3000

# WorkOS (ADR 0008) — required in production. Leaving these unset in
# development activates the demo principal (PLATFORM_ADMIN scoped to JAK
# demo operator). Do NOT leave these unset in production — the server
# fails closed: every request 401s without a valid bearer token.
#
# WORKOS_CLIENT_ID is enough on its own to derive the JWKS URL
# (https://api.workos.com/sso/jwks/<client_id>). Override with
# WORKOS_JWKS_URL for self-hosted AuthKit or custom-domain deployments.
#
# WORKOS_API_KEY is reserved for server-to-WorkOS Management API calls
# (e.g. user provisioning) and is not consumed by the JWT verifier.
#
# Operator scoping: the JWT's `org_id` claim is looked up against
# operators.config->>'workosOrganizationId' to find the operatorId.
# Provisioning a new operator deployment: store the WorkOS organization
# id in that jsonb field.
# WORKOS_API_KEY=
# WORKOS_CLIENT_ID=
# WORKOS_COOKIE_PASSWORD=
# WORKOS_JWKS_URL=
# WORKOS_ISSUER=https://api.workos.com

# Optional. Forwarded by the API only if a future route proxies the AI
# generator; today the assessment route lives in apps/web.
# ANTHROPIC_API_KEY=
